{
  "name": "simple-notes-extension",
  "version": "4.2.21",
  "description": "A simple notes extension using the side panel.",
  "private": true,
  "workspaces": [
    "packages/wysiwyg-markdown"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:editor && npm run build:extension && npm run package:amo-source",
    "build:editor": "npm run build --workspace @sidenote/wysiwyg-markdown",
    "build:app": "tsc -p tsconfig.extension.json",
    "build:extension": "npm run build:app && node build.js",
    "clean": "rimraf build packages/wysiwyg-markdown/dist",
    "package:amo-source": "node scripts/create-amo-source-package.mjs",
    "release:amo": "npm run build",
    "test": "vitest",
    "test:editor": "npm run test:run --workspace @sidenote/wysiwyg-markdown",
    "test:extension": "vitest run",
    "test:run": "npm run test:editor && npm run test:extension",
    "typecheck": "npm run typecheck:app && npm run typecheck --workspace @sidenote/wysiwyg-markdown",
    "typecheck:app": "tsc -p tsconfig.extension.json --noEmit"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.5",
    "archiver": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "glob": "^10.4.1",
    "jsdom": "^28.1.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "braces": "^3.0.3",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.9.0",
    "highlightjs-line-numbers.js": "^2.8.0",
    "jszip": "^3.10.1",
    "marked": "^10.0.0",
    "normalize.css": "^8.0.1",
    "reset-css": "^5.0.2",
    "webextension-polyfill": "^0.10.0"
  }
}
